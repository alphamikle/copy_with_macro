    "version": "0.2.0",
    "configurations": [
        {
            "name": "copy_with_macro",
            "request": "launch",
            "program": "example/main.dart",
            "type": "dart",
            "toolArgs": [
                "--enable-experiment=macros",
            ],
        },
        {
            "name": "copy_with_macro (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "toolArgs": [
                "--enable-experiment=macros",
            ],
        },
        {
            "name": "copy_with_macro (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "toolArgs": [
                "--enable-experiment=macros",
            ],
        },
        {
            "name": "quiver",
            "cwd": "lib/src/modules/quiver",
            "request": "launch",
            "type": "dart"
        }
    ]
}